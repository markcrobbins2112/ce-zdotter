{
	"name": "zdotter",
	"displayName": "zdotter",
	"version": "0.0.3",
	"description": "Manage zdots/zdashes and their index files.",
	"publisher": "markrobbins",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"main": "dist/extension.cjs",
	"icon": "icon.jpg",
	"files": [
		"dist/extension.cjs",
		"icon.jpg",
		"AILOG.md",
		"AITASKS.md",
		"AGENTS.md",
		"BUILD.md",
		"CODE.md",
		"FEATURES.md",
		"MANUAL.md",
		"README.md",
		"SPEC.md",
		"TESTING.md",
		"LICENSE"
	],
	"scripts": {
		"compile": "bun build.js",
		"watch": "bun build.js --watch",
		"vscode:prepublish": "bun build.js --production",
		"package": "vsce package",
		"install-vsix": "powershell -Command \"Get-Item *.vsix | Select-Object -First 1 | Foreach-Object { code --install-extension $_.FullName }\"",
		"lint": "bun build.js && node --check dist/extension.cjs",
		"unzip:latest": "bun unzip-latest.js zip.zip",
		"compile:vsix": "npx vsce package",
		"x:vscode:prepublish": "npm run compile",
		"x:compile": "tsc -p ./",
		"xwatch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/adm-zip": "^0.5.8",
		"@types/bun": "^1.3.14",
		"@types/node": "^22.14.0",
		"@types/source-map-support": "^0.5.10",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.6.2",
		"adm-zip": "^0.5.17",
		"source-map-support": "^0.5.21",
		"typescript": "~5.8.2",
		"vsce": "^1.25.1"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/markchristianrobbins/zdotter.git"
	},
	"bugs": {
		"url": "https://github.com/markchristianrobbins/zdotter/issues"
	},
	"homepage": "https://github.com/markchristianrobbins/zdotter#readme",
	"activationEvents": [
	],
	"contributes": {
		"configuration": {
			"title": "zdotter",
			"properties": {
				"zdotter.zdotdir": {
					"type": "string",
					"default": "",
					"description": "Root directory for zdoti files. Leave blank to default to <workspace>/.zdotter (or your home directory if no workspace is open). You really should assign this from a global directory so zdots will work anywhere"
				},
				"zdotter.outputTemplate1": {
					"type": "string",
					"default": "z.${z}",
					"description": "Template for Insert Zdot Template 1. ${z} is replaced with the zdot value."
				},
				"zdotter.outputTemplate2": {
					"type": "string",
					"default": "[${z}]",
					"description": "Template for Insert Zdot Template 2. ${z} is replaced with the zdot value."
				},
				"zdotter.outputTemplate3": {
					"type": "string",
					"default": "<a id=\"z${z}\"></a>",
					"description": "Template for Insert Zdot Template 2. ${z} is replaced with the zdot value."
				},
				"zdotter.outputTemplate4": {
					"type": "string",
					"default": "[${z}]",
					"description": "Template for Insert Zdot Template 2. ${z} is replaced with the zdot value."
				},
				"zdotter.freezeCursorOnInsert": {
					"type": "boolean",
					"default": false,
					"description": "When true, insert commands keep the cursor at its original position instead of moving after inserted text."
				}
			}
		},
		"commands": [
			{
				"command": "zdotter.insertZdot",
				"title": "zdotter: Insert zdot"
			},
			{
				"command": "zdotter.insertTemplate1",
				"title": "zdotter: Insert zdot Template 1"
			},
			{
				"command": "zdotter.insertTemplate2",
				"title": "zdotter: Insert zdot Template 2"
			},
			{
				"command": "zdotter.insertTemplate3",
				"title": "zdotter: Insert zdot Template 3"
			},
			{
				"command": "zdotter.insertTemplate4",
				"title": "zdotter: Insert zdot Template 4"
			},
			{
				"command": "zdotter.toggleFreezeCursorOnInsert",
				"title": "zdotter: Toggle Freeze Cursor On Insert"
			},
			{
				"command": "zdotter.updateFile",
				"title": "zdotter: Update File zdoti references"
			},
			{
				"command": "zdotter.gotoZdot",
				"title": "zdotter: Goto zdot from zdash"
			},
			{
				"command": "zdotter.gotoZdotExisting",
				"title": "zdotter: Goto zdot from zdash (focus existing)"
			},
			{
				"command": "zdotter.copyAsZdash",
				"title": "zdotter: Copy zdot as zdash"
			},
			{
				"command": "zdotter.zdashLine",
				"title": "zdotter: Zdash the line"
			},
			{
				"command": "zdotter.nextZdot",
				"title": "zdotter: Next zdot"
			},
			{
				"command": "zdotter.prevZdot",
				"title": "zdotter: Previous zdot"
			},
			{
				"command": "zdotter.nextZdash",
				"title": "zdotter: Next zdash"
			},
			{
				"command": "zdotter.prevZdash",
				"title": "zdotter: Previous zdash"
			},
			{
				"command": "zdotter.copyNearestDotAsDash",
				"title": "zdotter: Copy Nearest Dot As Dash"
			},
			{
				"command": "zdotter.openZdoti",
				"title": "zdotter: Open zdoti for zdot"
			}
		]
	}
}
